@model CreateTeacherSocialDto
@{
    ViewData["Title"] = "Sosyal Medya Ekle";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Yeni Sosyal Medya Ekle</h3>
                <p class="text-muted mb-0">
                    Sosyal medya hesabı bilgilerini aşağıdan ekleyebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm rounded">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Sosyal Medya Platformu</label>
                        <select asp-for="socialMediaId"
                                asp-items="ViewBag.socialMedias"
                                class="form-control">
                            <option value="">Sosyal Medya Seçiniz</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Link</label>
                        <input asp-for="url" class="form-control" placeholder="https://..." />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm rounded">
                <div class="card-body d-flex justify-content-end gap-2">

                    <a href="/Teacher/SocialMedia/Index/" class="btn btn-secondary">
                        <i class="mdi mdi-arrow-left"></i> Vazgeç
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="mdi mdi-content-save"></i> Kaydet
                    </button>

                </div>
            </div>
        </div>
    </div>
</form>