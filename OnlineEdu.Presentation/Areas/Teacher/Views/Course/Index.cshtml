@model List<ResultCourseDto>
@{
    ViewData["Title"] = "Kurslarım";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title mb-1">Kurs Yönetimi</h3>
                    <p class="text-muted mb-0">
                        Kurslarınızı buradan yönetebilirsiniz. Yeni kurs ekleyebilir,
                        mevcut kurslarınızı güncelleyebilir veya silebilirsiniz.
                    </p>
                </div>

                <a href="/Teacher/Course/CreateCourse/" class="btn btn-success">
                    <i class="mdi mdi-plus-circle"></i> Yeni Ekle
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th width="60">#</th>
                                <th>Görsel</th>
                                <th>Kurs Adı</th>
                                <th>Kategori</th>
                                <th>Fiyat</th>
                                <th width="260">İşlemler</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int count = 0;
                                foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td>@count</td>
                                        <td>
                                            <img src="@item.imageUrl"
                                                 style="width:75px;height:55px;object-fit:cover;border-radius:8px;" />
                                        </td>
                                        <td>
                                            @(item.courseName.Length > 40
                                                ? item.courseName.Substring(0, 40) + "..."
                                                : item.courseName)
                                        </td>
                                        <td>
                                            <span class="badge bg-info text-white px-3 py-2">
                                                @item.courseCategoryName
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-success px-3 py-2">
                                                @item.price ₺
                                            </span>
                                        </td>
                                        <td>
                                            <a href="javascript:void(0)"
                                               onclick="deleteCourse(@item.courseId)"
                                               class="btn btn-danger btn-sm">
                                                <i class="mdi mdi-delete"></i> Sil
                                            </a>
                                            <a href="/Teacher/Course/UpdateCourse/@item.courseId"
                                               class="btn btn-warning btn-sm text-white">
                                                <i class="mdi mdi-pencil"></i> Güncelle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">
                                        Kayıt bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function deleteCourse(id) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: "Bu kurs silinecek.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Teacher/Course/DeleteCourse/' + id;
            }
        });
    }
</script>