@model List<ResultContactDto>
@{
    ViewData["Title"] = "İletişim Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title mb-1">İletişim Yönetimi</h3>
                    <p class="text-muted mb-0">
                        İletişim bilgilerini buradan yönetebilirsiniz. Ana Sayfa yapısının bozulmaması adına tek kayıt kullanmanız önerilir.
                    </p>
                </div>
                <a href="/Admin/Contact/CreateContact" class="btn btn-success">
                    <i class="mdi mdi-plus-circle"></i> Yeni Ekle
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th width="80">#</th>
                                <th>Harita</th>
                                <th>Adres</th>
                                <th>Telefon</th>
                                <th>E-posta</th>
                                <th width="220">İşlemler</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int count = 0;

                                foreach (var item in Model)
                                {
                                    count++;

                                    <tr>
                                        <td>@count</td>

                                        <td><a href="@item.mapUrl" target="_blank" class="btn btn-info btn-sm text-white"><i class="mdi mdi-map"></i>Haritayı Aç</a></td>
                                        <td>@item.address</td>

                                        <td>@item.phone</td>

                                        <td>@item.email</td>

                                        <td>
                                            <a href="javascript:void(0)"
                                               onclick="deleteContact(@item.contactId)"
                                               class="btn btn-danger btn-sm">
                                                <i class="mdi mdi-delete"></i> Sil
                                            </a>

                                            <a href="/Admin/Contact/UpdateContact/@item.contactId"
                                               class="btn btn-warning btn-sm text-white">
                                                <i class="mdi mdi-pencil"></i> Güncelle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        Kayıt bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function deleteContact(id) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: "Bu iletişim kaydı silinecek!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Admin/Contact/DeleteContact/' + id;
            }
        })
    }
</script>

