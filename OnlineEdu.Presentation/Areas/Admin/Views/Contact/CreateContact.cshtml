@model CreateContactDto
@{
    ViewData["Title"] = "İletişim Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Yeni İletişim Kaydı</h3>
                <p class="text-muted mb-0">
                    İletişim bilgilerini aşağıdaki form üzerinden ekleyebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm rounded">
                <div class="card-body">

                    <!-- Map URL -->
                    <div class="mb-3">
                        <label class="form-label">Google Haritalar URL</label>
                        <input asp-for="mapUrl"
                               class="form-control"
                               placeholder="Örnek: https://www.google.com/maps/embed?pb=..." />
                    </div>

                    <!-- Address -->
                    <div class="mb-3">
                        <label class="form-label">Adres</label>
                        <textarea asp-for="address"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Adres bilgisi giriniz"></textarea>
                    </div>

                    <!-- Phone -->
                    <div class="mb-3">
                        <label class="form-label">Telefon</label>
                        <input asp-for="phone"
                               class="form-control"
                               placeholder="Telefon numarası giriniz" />
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label">E-posta</label>
                        <input asp-for="email"
                               type="email"
                               class="form-control"
                               placeholder="E-posta adresi giriniz" />
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Butonlar -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm rounded">
                <div class="card-body d-flex justify-content-end gap-2">
                    <a href="/Admin/Contact/Index/" class="btn btn-secondary">
                        <i class="mdi mdi-arrow-left"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="mdi mdi-content-save"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>