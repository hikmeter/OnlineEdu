@model CreateAboutDto
@{
    ViewData["Title"] = "Hakkımızda Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Yeni Hakkımızda Kaydı</h3>
                <p class="text-muted mb-0">
                    Hakkımızda alanına ait içerikleri aşağıdaki form üzerinden ekleyebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm rounded">
                <div class="card-body">
                    <div class="mb-3">

                        <label class="form-label">Açıklama</label>
                        <textarea asp-for="description" rows="6" class="form-control" placeholder="Hakkımızda açıklamasını giriniz"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Görsel Url 1</label>
                            <input asp-for="imageUrl1" class="form-control" placeholder="1. görsel bağlantısı" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Görsel Url 2</label>
                            <input asp-for="imageUrl2" class="form-control" placeholder="2. görsel bağlantısı" />
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Sağ Alan -->
        <div class="col-md-4">
            <div class="card shadow-sm rounded">
                <div class="card-body">
                    <h5 class="mb-3">Özellik Maddeleri</h5>
                    <div class="mb-3">
                        <label class="form-label">Madde 1</label>
                        <input asp-for="item1" class="form-control" placeholder="1. özellik" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Madde 2</label>
                        <input asp-for="item2" class="form-control" placeholder="2. özellik" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Madde 3</label>
                        <input asp-for="item3" class="form-control" placeholder="3. özellik" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Madde 4</label>
                        <input asp-for="item4" class="form-control" placeholder="4. özellik" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Butonlar -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm rounded">
                <div class="card-body d-flex justify-content-end gap-2">
                    <a href="/Admin/About/Index/" class="btn btn-secondary">
                        <i class="mdi mdi-arrow-left"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="mdi mdi-content-save"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>