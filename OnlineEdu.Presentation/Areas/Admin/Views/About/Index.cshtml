@model List<ResultAboutDto>
@{
    ViewData["Title"] = "Hakkımızda";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title mb-1">Hakkımızda Yönetimi</h3>
                    <p class="text-muted mb-0">
                        Hakkımızda içeriklerini buradan yönetebilirsiniz. Sayfa düzeninin bozulmaması için yalnızca bir kayıt bulunması önerilir.
                    </p>
                </div>

                <a href="/Admin/About/CreateAbout/" class="btn btn-success">
                    <i class="mdi mdi-plus-circle"></i> Yeni Ekle
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>#</th>
                                <th>Açıklama</th>
                                <th>Görsel 1</th>
                                <th>Görsel 2</th>
                                <th>Özellikler</th>
                                <th width="220">İşlemler</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int count = 0;

                                foreach (var item in Model)
                                {
                                    count++;

                                    <tr>
                                        <td>@count</td>

                                        <td>
                                            @(item.description.Length > 80
                                                ? item.description.Substring(0, 80) + "..."
                                                : item.description)
                                        </td>

                                        <td>
                                            <img src="@item.imageUrl1"
                                                 style="width:70px;height:55px;object-fit:cover;border-radius:8px;" />
                                        </td>

                                        <td>
                                            <img src="@item.imageUrl2"
                                                 style="width:70px;height:55px;object-fit:cover;border-radius:8px;" />
                                        </td>

                                        <td>
                                            <ul class="mb-0 ps-3">
                                                <li>@item.item1</li>
                                                <li>@item.item2</li>
                                                <li>@item.item3</li>
                                                <li>@item.item4</li>
                                            </ul>
                                        </td>

                                        <td>
                                            <a href="/Admin/About/DeleteAbout/@item.aboutId"
                                               class="btn btn-danger btn-sm">
                                                <i class="mdi mdi-delete"></i> Sil
                                            </a>

                                            <a href="/Admin/About/UpdateAbout/@item.aboutId"
                                               class="btn btn-warning btn-sm text-white">
                                                <i class="mdi mdi-pencil"></i> Güncelle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        Kayıt bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    </div>
</div>