@model UpdateRoleDto
@{
    ViewData["Title"] = "Rol Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Rol Güncelle</h3>
                <p class="text-muted mb-0">
                    Kullanıcılar için mevcut rol bilgisini aşağıdaki form üzerinden güncelleyebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm rounded">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Rol Adı</label>
                        <input asp-for="Name"
                               class="form-control"
                               placeholder="Rol adını giriniz" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm rounded">
                <div class="card-body d-flex justify-content-end gap-2">
                    <a href="/Admin/Role/Index/" class="btn btn-secondary">
                        <i class="mdi mdi-arrow-left"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn btn-warning text-white">
                        <i class="mdi mdi-content-save-edit"></i> Güncelle
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>