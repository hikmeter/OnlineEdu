@model CreateRoleDto
@{
    ViewData["Title"] = "Rol Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Yeni Rol Kaydı</h3>
                <p class="text-muted mb-0">
                    Kullanıcılar için yeni rol bilgisini aşağıdaki form üzerinden ekleyebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm rounded">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Rol Adı</label>
                        <input asp-for="Name"
                               class="form-control"
                               placeholder="Rol adını giriniz" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm rounded">
                <div class="card-body d-flex justify-content-end gap-2">
                    <a href="/Admin/Role/Index/" class="btn btn-secondary">
                        <i class="mdi mdi-arrow-left"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="mdi mdi-content-save"></i> Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>