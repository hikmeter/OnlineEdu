@model List<ResultMessageDto>
@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Gelen Kutusu</h3>
                <p class="text-muted mb-0">
                    Kullanıcılardan gelen mesajları buradan görüntüleyebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th width="60">#</th>
                                <th>Gönderen</th>
                                <th>Email</th>
                                <th>Konu</th>
                                <th width="160">İşlem</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int count = 0;

                                foreach (var item in Model)
                                {
                                    count++;

                                    <tr>
                                        <td>@count</td>

                                        <td>
                                            <strong>@item.name</strong>
                                        </td>

                                        <td>
                                            <span class="text-muted">
                                                @item.email
                                            </span>
                                        </td>

                                        <td>
                                            @(item.subject.Length > 50
                                                ? item.subject.Substring(0, 50) + "..."
                                                : item.subject)
                                        </td>

                                        <td>
                                            <a href="/Admin/Message/ReadMessage/@item.messageId"
                                               class="btn btn-primary btn-sm">
                                                <i class="mdi mdi-email-open-outline"></i> Oku
                                            </a>

                                            <a href="javascript:void(0)"
                                               onclick="deleteMessage(@item.messageId)"
                                               class="btn btn-danger btn-sm">
                                                <i class="mdi mdi-delete"></i> Sil
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">
                                        Gelen mesaj bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function deleteMessage(id) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: "Bu mesaj silinecek!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Admin/Message/DeleteMessage/' + id;
            }
        })
    }
</script>