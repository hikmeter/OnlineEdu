@model GetMessageByIdDto
@{
    ViewData["Title"] = "Mesaj Görüntüle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title mb-1">Mesaj Detayı</h3>
                    <p class="text-muted mb-0">
                        Gelen mesajın detaylarını görüntülüyorsunuz.
                    </p>
                </div>

                <a href="/Admin/Message/Index/" class="btn btn-secondary">
                    <i class="mdi mdi-arrow-left"></i> Gelen Kutusu
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow rounded">

            <!-- HEADER -->
            <div class="card-body border-bottom">
                <h4 class="mb-3 fw-bold">@Model.subject</h4>

                <div class="d-flex justify-content-between flex-wrap">
                    <div>
                        <strong>@Model.name</strong>
                        <br />
                        <span class="text-muted">@Model.email</span>
                    </div>

                    <div>
                        <span class="badge bg-info text-white px-3 py-2">
                            Gelen Mesaj
                        </span>
                    </div>
                </div>
            </div>

            <!-- CONTENT -->
            <div class="card-body">

                <div style="line-height:1.8; font-size:15px; white-space:pre-line;">
                    @Model.content
                </div>

            </div>

            <!-- FOOTER -->
            <div class="card-footer bg-light d-flex justify-content-end gap-2">

                <a href="/Admin/Message/Index/" class="btn btn-outline-secondary">
                    <i class="mdi mdi-arrow-left"></i> Geri Dön
                </a>

                <a href="mailto:@Model.email" class="btn btn-primary">
                    <i class="mdi mdi-reply"></i> Yanıtla
                </a>
            </div>
        </div>
    </div>
</div>