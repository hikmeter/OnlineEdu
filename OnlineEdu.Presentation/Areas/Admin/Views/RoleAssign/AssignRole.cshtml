@model List<AssignRoleDto>
@{
    ViewData["Title"] = "Rol Atama";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Rol Atama</h3>
                <p class="text-muted mb-0">
                    Kullanıcıya atanacak rolleri seçebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <input type="hidden" name="id" value="@ViewBag.UserId" />
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm rounded">
                <div class="card-body">

                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <div class="form-check mb-3">
                            <input type="hidden"
                                   asp-for="@Model[i].RoleId" />
                            <input type="hidden"
                                   asp-for="@Model[i].RoleName" />
                            <input class="form-check-input"
                                   asp-for="@Model[i].IsRoleExists" />
                            <label class="form-check-label">
                                @Model[i].RoleName
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="card shadow-sm rounded">
                <div class="card-body d-flex justify-content-end gap-2">

                    <a href="/Admin/User/Index/"
                       class="btn btn-secondary">
                        Vazgeç
                    </a>
                    <button type="submit"
                            class="btn btn-primary">
                        Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>

</form>