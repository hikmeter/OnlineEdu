@model List<ResultTestimonialDto>

@{
    ViewData["Title"] = "Referans Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title mb-1">Referans Yönetimi</h3>
                    <p class="text-muted mb-0">
                        Öğrenci yorumlarını ve referans içeriklerini buradan yönetebilirsiniz.
                    </p>
                </div>

                <a href="/Admin/Testimonial/CreateTestimonial" class="btn btn-success">
                    <i class="mdi mdi-plus-circle"></i> Yeni Referans Ekle
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">

                        <thead class="bg-dark text-white">
                            <tr>
                                <th width="70">#</th>
                                <th>Görsel</th>
                                <th>Ad Soyad</th>
                                <th>Ünvan</th>
                                <th>Yorum</th>
                                <th>Puan</th>
                                <th width="220">İşlemler</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (Model != null && Model.Any())
                            {
                                int count = 0;

                                foreach (var item in Model)
                                {
                                    count++;

                                    <tr>
                                        <td>@count</td>

                                        <td>
                                            <img src="@item.imageUrl"
                                                 style="width:70px;height:70px;object-fit:cover;border-radius:50%;" />
                                        </td>

                                        <td>@item.name</td>

                                        <td>@item.title</td>

                                        <td style="max-width:350px;">
                                            @(item.comment.Length > 120
                                                ? item.comment.Substring(0, 120) + "..."
                                                : item.comment)
                                        </td>

                                        <td>
                                            @for (int i = 0; i < item.star; i++)
                                            {
                                                <i class="mdi mdi-star text-warning"></i>
                                            }
                                        </td>

                                        <td>
                                            <a href="javascript:void(0)"
                                               onclick="deleteTestimonial(@item.testimonialId)"
                                               class="btn btn-danger btn-sm">
                                                <i class="mdi mdi-delete"></i> Sil
                                            </a>

                                            <a href="/Admin/Testimonial/UpdateTestimonial/@item.testimonialId"
                                               class="btn btn-warning btn-sm text-white">
                                                <i class="mdi mdi-pencil"></i> Güncelle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }

                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">
                                        Kayıt bulunamadı.
                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    function deleteTestimonial(id) {

        Swal.fire({
            title: 'Emin misiniz?',
            text: "Bu referans kaydı silinecek!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç'

        }).then((result) => {

            if (result.isConfirmed) {
                window.location.href = '/Admin/Testimonial/DeleteTestimonial/' + id;
            }

        })
    }
</script>