@model UpdateTestimonialDto
@{
    ViewData["Title"] = "Referans Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <h3 class="card-title mb-1">Yeni Referans Kaydı</h3>
                <p class="text-muted mb-0">
                    Mevcut öğrenci veya kullanıcı yorumlarını aşağıdaki form üzerinden güncelleyebilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="testimonialId" />
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm rounded">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Ad Soyad</label>
                        <input asp-for="name"
                               class="form-control"
                               placeholder="Ad soyad giriniz" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ünvan</label>
                        <input asp-for="title"
                               class="form-control"
                               placeholder="Örnek: Öğrenci, Yazılım Geliştirici..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Görsel URL</label>
                        <input asp-for="imageUrl"
                               class="form-control"
                               placeholder="Görsel bağlantısı giriniz" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Yorum</label>
                        <textarea asp-for="comment"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Kullanıcı yorumunu giriniz"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Puan</label>
                        <input asp-for="star"
                               type="number"
                               min="1"
                               max="5"
                               class="form-control"
                               placeholder="1 - 5 arasında puan giriniz" />
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Butonlar -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm rounded">
                <div class="card-body d-flex justify-content-end gap-2">
                    <a href="/Admin/Testimonial/Index/" class="btn btn-secondary">
                        <i class="mdi mdi-arrow-left"></i> Vazgeç
                    </a>
                    <button type="submit" class="btn btn-warning text-white">
                        <i class="mdi mdi-content-save-edit"></i> Güncelle
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>