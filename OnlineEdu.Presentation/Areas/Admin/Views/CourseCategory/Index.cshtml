@model List<ResultCourseCategoryDto>
@{
    ViewData["Title"] = "Kurs Kategorileri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title mb-1">Kurs Kategori Yönetimi</h3>
                    <p class="text-muted mb-0">
                        Kurs kategorilerini buradan yönetebilirsiniz.
                    </p>
                </div>
                <a href="/Admin/CourseCategory/CreateCourseCategory" class="btn btn-success">
                    <i class="mdi mdi-plus-circle"></i> Yeni Ekle
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th width="80">#</th>
                                <th>İkon</th>
                                <th>Kategori Adı</th>
                                <th>Açıklama</th>
                                <th>Durum</th>
                                <th width="220">İşlemler</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int count = 0;

                                foreach (var item in Model)
                                {
                                    count++;

                                    <tr>
                                        <td>@count</td>

                                        <td class="text-center">
                                            <i class="@item.icon" style="font-size:24px;"></i>
                                        </td>

                                        <td>@item.categoryName</td>

                                        <td>@item.description</td>

                                        <td>
                                            @if (item.isShown)
                                            {
                                                <span class="badge bg-success text-white">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Pasif</span>
                                            }
                                            <a href="/Admin/CourseCategory/ToggleShownStatus/@item.courseCategoryId" class="btn btn-info btn-sm">Değiştir</a>
                                        </td>

                                        <td>
                                            <a href="javascript:void(0)"
                                               onclick="deleteCourseCategory(@item.courseCategoryId)"
                                               class="btn btn-danger btn-sm">
                                                <i class="mdi mdi-delete"></i> Sil
                                            </a>

                                            <a href="/Admin/CourseCategory/UpdateCourseCategory/@item.courseCategoryId"
                                               class="btn btn-warning btn-sm text-white">
                                                <i class="mdi mdi-pencil"></i> Güncelle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        Kayıt bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function deleteCourseCategory(id) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: "Bu kategori silinecek!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Admin/CourseCategory/DeleteCourseCategory/' + id;
            }
        })
    }
</script>

