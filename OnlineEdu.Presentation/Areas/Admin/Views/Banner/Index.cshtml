@model List<ResultBannerDto>
@{
    ViewData["Title"] = "Afiş";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title mb-1">Afiş Yönetimi</h3>
                    <p class="text-muted mb-0">
                        Ana sayfada gösterilen afiş içeriklerini buradan yönetebilirsiniz.</p>
                </div>
                <a href="/Admin/Banner/CreateBanner/" class="btn btn-success">
                    <i class="mdi mdi-plus-circle"></i> Yeni Ekle
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm rounded">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>#</th>
                                <th>Başlık</th>
                                <th>Görsel</th>
                                <th width="220">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int count = 0;

                                foreach (var item in Model)
                                {
                                    count++;

                                    <tr>
                                        <td>@count</td>

                                        <td>
                                            @(item.title.Length > 60
                                                ? item.title.Substring(0, 60) + "..."
                                                : item.title)
                                        </td>

                                        <td>
                                            <img src="@item.imageUrl"
                                                 style="width:120px;height:60px;object-fit:cover;border-radius:8px;" />
                                        </td>

                                        <td>
                                            <a href="/Admin/Banner/DeleteBanner/@item.bannerId"
                                               class="btn btn-danger btn-sm">
                                                <i class="mdi mdi-delete"></i> Sil
                                            </a>

                                            <a href="/Admin/Banner/UpdateBanner/@item.bannerId"
                                               class="btn btn-warning btn-sm text-white">
                                                <i class="mdi mdi-pencil"></i> Güncelle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">
                                        Kayıt bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>