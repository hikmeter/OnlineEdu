@{
	Layout = null;
}

<!doctype html>
<html class="no-js" lang="zxx">
<head>
	<meta charset="utf-8">
	<meta http-equiv="x-ua-compatible" content="ie=edge">
	<title>OnlineEdu- Eğitimin Çevrimiçi Hali</title>
	<meta name="description" content="">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<link rel="manifest" href="site.webmanifest">
	<link rel="shortcut icon" type="image/x-icon" href="~/onlineedu-master/assets/img/favicon.ico">

	<!-- CSS here -->
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/bootstrap.min.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/owl.carousel.min.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/slicknav.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/flaticon.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/gijgo.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/animate.min.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/magnific-popup.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/fontawesome-all.min.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/themify-icons.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/slick.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/nice-select.css">
	<link rel="stylesheet" href="~/onlineedu-master/assets/css/style.css">
</head>
<body>
	<!--? Preloader Start -->
	<div id="preloader-active">
		<div class="preloader d-flex align-items-center justify-content-center">
			<div class="preloader-inner position-relative">
				<div class="preloader-circle"></div>
				<div class="preloader-img pere-text">
					<img src="~/onlineedu-master/assets/img/logo/loder.png" alt="">
				</div>
			</div>
		</div>
	</div>
	<!-- Preloader Start -->
	<header>
		<!-- Header Start -->
		<div class="header-area">
			<div class="main-header ">
				<div class="header-top d-none d-lg-block">
					<!-- Left Social -->
					@await Component.InvokeAsync("_HomeSocialMediaComponentPartial")

					<div class="container">
						<div class="col-xl-12">
							<div class="row d-flex justify-content-between align-items-center">
								@await Component.InvokeAsync("_HomeContactInfoComponentPartial")
								<div class="header-info-right">
									<ul>
										<li><a href="/Login/SignIn"><i class="ti-user"></i>Giriş Yap</a></li>
										<li><a href="/Register/Signup"><i class="ti-lock"></i>Kayıt Ol</a></li>
									</ul>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="header-bottom header-sticky">
					<!-- Logo -->
					<div class="logo d-none d-lg-block">
						<a href="/Home/Index"><img src="~/onlineedu-master/assets/img/logo/logo.png" alt=""></a>
					</div>
					<div class="container">
						<div class="menu-wrapper">
							<!-- Logo -->
							<div class="logo logo2 d-block d-lg-none">
								<a href="/Home/Index"><img src="~/onlineedu-master/assets/img/logo/logo.png" alt=""></a>
							</div>
							<!-- Main-menu -->
							<div class="main-menu d-none d-lg-block">
								<nav>
									<ul id="navigation">
										<li><a href="/Home/Index">Ana Sayfa</a></li>
										<li><a href="/About/Index">Hakkımızda</a></li>
										<li><a href="/Course/Index">Kurslar</a></li>
										<li><a href="/Teacher/Index">Eğitmenler</a></li>
										<li><a href="/Blog/Index">Blog</a></li>
										<li><a href="contact.html">İletişim</a></li>
									</ul>
								</nav>
							</div>
							<!-- Header-btn -->
							<div class="header-search d-none d-lg-block">
								<form action="#" class="form-box f-right ">
									<input type="text" name="Search" placeholder="Kurs Ara">
									<div class="search-icon">
										<i class="fas fa-search special-tag"></i>
									</div>
								</form>
							</div>
						</div>
						<!-- Mobile Menu -->
						<div class="col-12">
							<div class="mobile_menu d-block d-lg-none"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- Header End -->
	</header>
	<main>
		@RenderBody()
	</main>
	<footer>
		<div class="footer-area footer-bg">
			<div class="container">
				<div class="footer-top footer-padding">
					<div class="footer-heading">
						<div class="row justify-content-between">
							<div class="col-xl-6 col-lg-7 col-md-10">
								<div class="footer-tittle2">
									<h4>Takipte Kalın</h4>
								</div>
								@await Component.InvokeAsync("_LayoutSubscriberComponentPartial")
							</div>
							<div class="col-xl-5 col-lg-5">
								<div class="footer-tittle2">
									<h4>İletişimde Kalalım</h4>
								</div>
								@await Component.InvokeAsync("_LayoutSocialMediaComponentPartial")
							</div>
						</div>
					</div>
					<!-- Footer Menu -->
					<div class="row d-flex justify-content-between">
						<div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
							<div class="single-footer-caption mb-50">
								<div class="footer-tittle">
									<h4>Hakkımızda</h4>
									<ul>
										<li><a href="/Home/Index">Ana Sayfa</a></li>
										<li><a href="/About/Index">Hakkımızda</a></li>
										<li><a href="/Course/Index">Kurslar</a></li>
										<li><a href="/Teacher/Index">Eğitmenlerimiz</a></li>
										<li><a href="/Contact/Index">İletişim</a></li>
									</ul>
								</div>
							</div>
						</div>
						<div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
							<div class="single-footer-caption mb-50">
								<div class="footer-tittle">
									<h4>Kampüs</h4>
									<ul>
										<li><a href="#">Misyonumuz</a></li>
										<li><a href="#">Vizyonumuz</a></li>
										<li><a href="#">Akademik Çözümler</a></li>
										<li><a href="#">İşletme Çözümleri</a></li>
										<li><a href="#">İnsan Kaynakları</a></li>
									</ul>
								</div>
							</div>
						</div>
						<div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
							<div class="single-footer-caption mb-50">
								<div class="footer-tittle">
									<h4>Çalışma</h4>
									<ul>
										<li><a href="#">İzin Politikası</a></li>
										<li><a href="#">Başlarken</a></li>
										<li><a href="#">Çevrimiçi Başvuru</a></li>
										<li><a href="#">Ders İçerikleri</a></li>
										<li><a href="#">Özel Fırsatlar</a></li>
									</ul>
								</div>
							</div>
						</div>
						<div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
							<div class="single-footer-caption mb-50">
								<div class="footer-tittle">
									<h4>Destek</h4>
									<ul>
										<li><a href="/Login/SignIn">Giriş Yap</a></li>
										<li><a href="/Register/Signup">Üye Ol</a></li>
										<li><a href="#">Destek</a></li>
										<li><a href="/Contact/Index">İletişim</a></li>
										<li><a href="#">Sistem Gereksinimleri</a></li>
									</ul>
								</div>
							</div>
						</div>
					</div>
				</div>
				<!-- Footer Bottom -->
				<div class="footer-bottom">
					<div class="row d-flex align-items-center">
						<div class="col-lg-12">
							<div class="footer-copy-right text-center">
								<p>
									Copyright &copy;<script>document.write(new Date().getFullYear());</script> Tüm Hakları Saklıdır. | <a href="https://colorlib.com" target="_blank">Colorlib</a> tarafından <i class="fa fa-heart" aria-hidden="true"></i> ile hazırlanmıştır.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- Footer End-->
	</footer>
	<!-- Scroll Up -->
	<div id="back-top">
		<a title="Go to Top" href="#"> <i class="fas fa-level-up-alt"></i></a>
	</div>

	<script src="~/onlineedu-master/assets/js/vendor/modernizr-3.5.0.min.js"></script>

	<!-- jQuery (HER ŞEYİN TEMELİ) -->
	<script src="~/onlineedu-master/assets/js/vendor/jquery-1.12.4.min.js"></script>

	<!-- Bootstrap dependencies -->
	<script src="~/onlineedu-master/assets/js/popper.min.js"></script>
	<script src="~/onlineedu-master/assets/js/bootstrap.min.js"></script>

	<!-- Plugin'ler (jQuery bağımlı olanlar) -->
	<script src="~/onlineedu-master/assets/js/jquery.slicknav.min.js"></script>
	<script src="~/onlineedu-master/assets/js/owl.carousel.min.js"></script>
	<script src="~/onlineedu-master/assets/js/slick.min.js"></script>
	<script src="~/onlineedu-master/assets/js/wow.min.js"></script>
	<script src="~/onlineedu-master/assets/js/animated.headline.js"></script>
	<script src="~/onlineedu-master/assets/js/jquery.magnific-popup.js"></script>
	<script src="~/onlineedu-master/assets/js/gijgo.min.js"></script>
	<script src="~/onlineedu-master/assets/js/jquery.nice-select.min.js"></script>
	<script src="~/onlineedu-master/assets/js/jquery.sticky.js"></script>
	<script src="~/onlineedu-master/assets/js/jquery.counterup.min.js"></script>
	<script src="~/onlineedu-master/assets/js/waypoints.min.js"></script>
	<script src="~/onlineedu-master/assets/js/jquery.form.js"></script>
	<script src="~/onlineedu-master/assets/js/jquery.validate.min.js"></script>
	<script src="~/onlineedu-master/assets/js/jquery.ajaxchimp.min.js"></script>

	<!-- Mail / theme script -->
	<script src="~/onlineedu-master/assets/js/mail-script.js"></script>
	<script src="~/onlineedu-master/assets/js/plugins.js"></script>
	<script src="~/onlineedu-master/assets/js/main.js"></script>

	<!-- SENİN CUSTOM SCRIPT (EN SON) -->
	<script src="~/Login & Signup Form/script.js"></script>

	<!-- SWEETALERT (EN SONUNA YAKIN) -->
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>