@{
    Layout = null;
}

<!DOCTYPE html>
<html dir="ltr" lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="">
    <link rel="icon" type="image/png" sizes="16x16" href="~/matrix-admin-master/assets/images/favicon.png">
    <title>Online Edu - Öğrenci Paneli</title>
    <link href="~/matrix-admin-master/assets/libs/magnific-popup/dist/magnific-popup.css" rel="stylesheet">
    <link href="~/matrix-admin-master/dist/css/style.min.css" rel="stylesheet">
    <style>
        .netflix-section {
            margin-top: 20px;
        }

        .netflix-title {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .netflix-row {
            display: flex;
            overflow-x: auto;
            justify-content: start;
            gap: 15px;
            padding-bottom: 10px;
            scroll-behavior: smooth;
        }

            .netflix-row::-webkit-scrollbar {
                height: 8px;
            }

            .netflix-row::-webkit-scrollbar-thumb {
                background: #ccc;
                border-radius: 10px;
            }

        .netflix-card {
            min-width: 260px;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            transition: 0.3s;
            flex-shrink: 0;
        }

            .netflix-card:hover {
                transform: scale(1.05);
            }

        .netflix-img {
            width: 100%;
            height: 150px;
            object-fit: cover;
        }

        .netflix-body {
            padding: 12px;
        }

        .netflix-title-text {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .netflix-category {
            font-size: 12px;
            color: #777;
            margin-bottom: 8px;
        }

        .netflix-price {
            font-weight: bold;
            color: #28a745;
            margin-bottom: 10px;
        }

        .netflix-btn {
            width: 100%;
            padding: 8px;
            border: none;
            border-radius: 8px;
            background: #e50914;
            color: white;
            cursor: pointer;
            transition: 0.2s;
        }

            .netflix-btn:hover {
                background: #b20710;
            }
        /* Üstteki Yeni Kurs Kayıt Butonu */
        .btn-create-course {
            display: inline-flex;
            align-items: center;
            padding: 10px 20px;
            background-color: #e50914; /* Netflix Kırmızısı */
            color: #fff;
            border: none;
            border-radius: 4px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(229, 9, 20, 0.3);
            margin-bottom: 20px;
        }

            .btn-create-course:hover {
                background-color: #ff0a16;
                color: #fff;
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(229, 9, 20, 0.4);
                text-decoration: none;
            }

            .btn-create-course i {
                margin-right: 8px;
            }

        /* Başlık alanını butonla hizalamak için küçük bir dokunuş */
        .netflix-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .netflix-title {
            margin-bottom: 0 !important; /* Header içinde hizalama için */
        }
    </style>
</head>

<body>
