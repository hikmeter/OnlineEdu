@model List<ResultBlogDto>
<div class="home-blog-area section-padding30">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="section-tittle text-center mb-50">
                    <span>Blogumuza Göz Atın</span>
                    <h2>Blog Yazarlarımızdan Son Haberler</h2>
                </div>
            </div>
        </div>
        <div class="row">
            @foreach(var item in Model)
            {
                <div class="col-xl-6 col-lg-6 col-md-6">
                    <div class="home-blog-single mb-30">
                        <div class="blog-img-cap">
                            <div class="blog-img">
                                <img src="@item.imageUrl" alt="Blog" style="width: 575px; height: 345px">
                                <div class="blog-date text-center">
                                    <span>@item.blogDate.Day</span>
                                    <p>@item.blogDate.ToString("MMMM", new System.Globalization.CultureInfo("tr-TR"))</p>
                                </div>
                            </div>
                            <div class="blog-cap">
                                <p>|   @item.blogCategoryName</p>
                                <h3><a href="blog_details.html">@item.title</a></h3>
                                <a href="blog_details.html" class="more-btn">Devamını Oku »</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>