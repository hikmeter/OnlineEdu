@model List<ResultBlogDto>
<aside class="single_sidebar_widget popular_post_widget">
	<h3 class="widget_title" style="color: #2d2d2d;">Son Bloglar</h3>
	@foreach (var item in Model)
	{
		<div class="media post_item">
			<img src="@item.imageUrl" style="width:80px; height:80px" alt="blog">
			<div class="media-body">
				<a href="/Blog/BlogDetail/@item.blogId">
					<h3 style="color: #2d2d2d;">@(item.title.Length > 80 ? item.title.Substring(0, 80) + "..." : item.title)</h3>
				</a>
				<p>@item.blogDate.Day @item.blogDate.ToString("MMMM", new System.Globalization.CultureInfo("tr-TR")) @item.blogDate.Year</p>
			</div>
		</div>
	}
</aside>