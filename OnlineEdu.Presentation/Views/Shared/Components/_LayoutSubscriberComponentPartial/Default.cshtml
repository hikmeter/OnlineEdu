﻿<div class="footer-form mb-50">
    <form method="post" asp-action="Subscribe" asp-controller="Blog">
        <div class="form-group">
            <input type="email" name="email" class="form-control" onfocus="this.placeholder = ''"
                   onblur="this.placeholder = 'E-posta Adresiniz'" placeholder='E-Posta Adresinizi Yazın.' required="">
        </div>
        <button onclick="subscribe()" class="button rounded-0 primary-bg text-white w-100 btn_1 boxed-btn"
                type="submit">
            Abone Ol
        </button>
    </form>
</div>