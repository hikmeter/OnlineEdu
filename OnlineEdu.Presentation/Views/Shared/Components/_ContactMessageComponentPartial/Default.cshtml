@model CreateMessageDto
<div class="col-lg-8">
    <form class="form-contact contact_form" asp-action="SendMessage" asp-controller="Contact" method="post" id="contactForm" novalidate="novalidate">
        <div class="row">
            <div class="col-12">
                <div class="form-group">
                    <textarea class="form-control w-100" asp-for="content" id="message" cols="30" rows="9" onfocus="this.placeholder = ''" onblur="this.placeholder = 'Mesajınızı Yazınız.'" placeholder=" Mesajınızı Yazınız."></textarea>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="form-group">
                    <input class="form-control valid" asp-for="name" id="name" type="text" onfocus="this.placeholder = ''" onblur="this.placeholder = 'Adınızı ve Soyadınızı Yazınız.'" placeholder="Adınızı ve Soyadınızı Yazınız.">
                </div>
            </div>
            <div class="col-sm-6">
                <div class="form-group">
                    <input class="form-control valid" asp-for="email" id="email" type="email" onfocus="this.placeholder = ''" onblur="this.placeholder = 'E-Posta Adresinizi Yazınız.'" placeholder="E-Posta Adresinizi Yazınız.">
                </div>
            </div>
            <div class="col-12">
                <div class="form-group">
                    <input class="form-control" asp-for="subject" id="subject" type="text" onfocus="this.placeholder = ''" onblur="this.placeholder = 'Konuyu Yazınız.'" placeholder="Konuyu Yazınız.">
                </div>
            </div>
        </div>
        <div class="form-group mt-3">
            <button type="submit" class="button button-contactForm boxed-btn">Gönder</button>
        </div>
    </form>
</div>

<script>
    $(document).ready(function () {
        $("#contactForm").submit(function (e) {
            e.preventDefault();
            $.ajax({
                url: '/Contact/SendMessage',
                type: 'POST',
                data: $(this).serialize(),
                success: function () {
                    Swal.fire({
                        icon: 'success',
                        title: 'Başarılı!',
                        text: 'Mesajınız başarıyla gönderildi.'
                    });
                    $("#contactForm")[0].reset();
                },

                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Hata!',
                        text: 'Mesaj gönderilirken bir hata oluştu.'
                    });
                }
            });
        });
    });
</script>