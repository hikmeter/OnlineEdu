@model List<ResultCourseCategoryDto>
<div class="categories-area section-padding30">
    <div class="container">
        <div class="row justify-content-sm-center">
            <div class="cl-xl-7 col-lg-8 col-md-10">
                <!-- Section Tittle -->
                <div class="section-tittle text-center mb-70">
                    <span>En Çok Tercih Edilen Çevrimiçi Kurslar</span>
                    <h2>Sana Uygun Olanı Seç</h2>
                </div>
            </div>
        </div>
        <div class="row">
            @foreach(var item in Model)
            {
                <div class="col-lg-4 col-md-6 col-sm-6">
                    <div class="single-cat mb-50">
                        <div class="cat-icon">
                            <span class="@item.icon"></span>
                        </div>
                        <div class="cat-cap">
                            <h5><a href="/Course/GetCoursesByCategoryId/@item.courseCategoryId">@item.categoryName</a></h5>
                            <p>@item.description</p>
                            <a href="/Course/GetCoursesByCategoryId/@item.courseCategoryId" class="read-more1">Dahası ></a>
                        </div>
                    </div>
                </div>
            }
            
        </div>
        <!-- Section Button -->
        <div class="row">
            <div class="col-lg-12">
                <div class="browse-btn2 text-center mt-50">
                    <a href="courses.html" class="btn">Daha Fazla Kurs</a>
                </div>
            </div>
        </div>
    </div>
</div>