@model List<ResultAboutDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main>
    <div class="slider-area">
        <div class="slider-height2 d-flex align-items-center">
            <div class="container">
                <div class="row">
                    <div class="col-xl-12">
                        <div class="hero-cap hero-cap2 text-center">
                            <h2>Hakkımızda</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="about-details section-padding30">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="about-details-cap mb-50">
                        <h4>Misyonumuz</h4>
                            <p>@Model.ElementAtOrDefault(1)?.description</p>
                    </div>

                    <div class="about-details-cap mb-50">
                        <h4>Vizyonumuz</h4>
                        <p>@Model.ElementAtOrDefault(2)?.description</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("_HomeCounterComponentPartial")
    <!-- Count Down End -->
    <!--? Testimonial Start -->
    @await Component.InvokeAsync("_HomeTestimonialComponentPartial")
    <!-- Testimonial End -->
    <!--? About  Start-->
    @await Component.InvokeAsync("_HomeAboutComponentPartial")
    <!-- About Law End-->
</main>

